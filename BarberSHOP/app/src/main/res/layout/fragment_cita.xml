<?xml version="1.0" encoding="utf-8"?>
<!-- Aqui se guardaran las citas que tiene el cliente con las barberias -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textSize="30sp"
            android:textColor="?attr/colorPrimary"
            android:text="Tus citas"/>

        <LinearLayout
            android:id="@+id/menu_citas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="20dp">
            <TextView
                android:id="@+id/tab_proximas_citas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:padding="12dp"
                android:layout_marginEnd="20dp"
                android:text="Proximas citas"
                android:background="@drawable/bg_section_selected"/>

            <TextView
                android:id="@+id/tab_historial_citas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historial citas"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="20dp"
                android:padding="12dp"
                android:background="@drawable/bg_section_noselected"/>
        </LinearLayout>

        <View
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/accent_gold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_citas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <!-- Por si no hay citas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="40dp">
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_calendario"
                android:tint="@color/gray_800" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="No tienes citas todavia"
                android:textColor="@color/gray_800"
                android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>