<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/home_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descubre"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="32sp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_notificaciones"
            android:tint="?attr/colorPrimary"
            android:layout_marginTop="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tv_subtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encuentra tu próxima barbería"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="@id/tv_titulo"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo"/>

        <!-- Barra de búsqueda -->
        <LinearLayout
            android:id="@+id/ll_barradebusqueda"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_search"
            android:orientation="horizontal"
            android:padding="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/et_busqueda"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:drawableStart="@drawable/buscar_gris"
                android:drawablePadding="5dp"
                android:inputType="textNoSuggestions"
                android:maxLines="1"
                android:hint="Buscar barberías, estilos, ciudades..."
                android:textColor="@color/black"
                android:textColorHint="@color/secondary_light"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Barberías cercanas -->
        <TextView
            android:id="@+id/tv_cercanas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/nuitosans"
            android:text="Barberías cercanas"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="19sp"
            app:layout_constraintTop_toBottomOf="@id/ll_barradebusqueda"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Barberías destacadas -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_cercanas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_cercanas"
            tools:itemCount="5"
            tools:listitem="@layout/item_barberia_home" />

        <TextView
            android:id="@+id/tv_destacadas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Barberías destacadas"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="19sp"
            app:layout_constraintTop_toBottomOf="@id/rv_cercanas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_destacadas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_destacadas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Mejor valoradas -->
        <TextView
            android:id="@+id/tv_top"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Mejor valoradas"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="19sp"
            app:layout_constraintTop_toBottomOf="@id/rv_destacadas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_top"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
