<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila superior: hora + estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/cita_barbero_hora"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/montserrat_bold"
                android:textSize="18sp"
                android:textColor="?attr/colorPrimary"/>

            <TextView
                android:id="@+id/cita_barbero_estado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_estado_cita"
                android:padding="6dp"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Nombre cliente -->
        <TextView
            android:id="@+id/cita_barbero_nombre_cliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/montserrat_bold"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"/>

        <!-- Servicio y precio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/cita_barbero_servicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/gray_600"/>

            <TextView
                android:id="@+id/cita_barbero_precio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:textSize="14sp"
                android:textColor="@color/accent_green"/>

        </LinearLayout>

        <!-- Botones Confirmar / Cancelar — solo si PENDIENTE -->
        <LinearLayout
            android:id="@+id/cita_barbero_botones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmar_cita"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Confirmar"
                android:textSize="13sp"
                app:backgroundTint="@color/accent_green"
                app:cornerRadius="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancelar_cita"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Cancelar"
                android:textSize="13sp"
                app:backgroundTint="@color/accent_red"
                app:cornerRadius="8dp"/>

        </LinearLayout>

        <!-- Botón COMPLETADA — solo si CONFIRMADA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_completar_cita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="✓ Marcar como completada"
            android:textSize="13sp"
            android:visibility="gone"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/checkbox_on_background"
            app:iconGravity="textStart"
            app:iconSize="16dp"/>

        <!-- Botón ELIMINAR — solo si CANCELADA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_eliminar_cita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Eliminar cita"
            android:textSize="13sp"
            android:visibility="gone"
            app:backgroundTint="@color/gray_600"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
