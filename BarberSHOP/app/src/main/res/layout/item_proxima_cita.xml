<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Foto de la barbería -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/cita_cliente_img_barberia"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/avatar_perfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Nombre barbería -->
        <TextView
            android:id="@+id/cita_cliente_nombre_barberia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/montserrat_bold"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toEndOf="@+id/cita_cliente_img_barberia"
            app:layout_constraintEnd_toStartOf="@+id/cita_cliente_estado"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Servicio -->
        <TextView
            android:id="@+id/cita_cliente_servicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="@color/gray_600"
            app:layout_constraintStart_toEndOf="@+id/cita_cliente_img_barberia"
            app:layout_constraintEnd_toStartOf="@+id/cita_cliente_estado"
            app:layout_constraintTop_toBottomOf="@+id/cita_cliente_nombre_barberia"/>

        <!-- Fecha y hora -->
        <TextView
            android:id="@+id/cita_cliente_fecha_hora"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toEndOf="@+id/cita_cliente_img_barberia"
            app:layout_constraintEnd_toStartOf="@+id/cita_cliente_estado"
            app:layout_constraintTop_toBottomOf="@+id/cita_cliente_servicio"/>

        <!-- Estado -->
        <TextView
            android:id="@+id/cita_cliente_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_estado_cita"
            android:padding="6dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>